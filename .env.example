# ─────────────────────────────────────────────
# FORGES Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FORGES

# Database (PostgreSQL / Neon / Supabase)
# For in-memory development, leave empty
DATABASE_URL=

# Authentication
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# OAuth Providers (optional, disabled by default)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# AI Providers
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Vercel Analytics (auto-injected on Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Billing (optional)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# Rate Limiting (optional, defaults to 100/min)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000
