#!/bin/sh
#
# Gradle start up script for POSIX-compatible shells on Unix-like operating systems.
# Generated by the official Gradle wrapper; see https://docs.gradle.org/current/userguide/gradle_wrapper.html
#
# NOTE: gradle/wrapper/gradle-wrapper.jar must be present for this script to work.
# If it is missing, regenerate it by running:
#   gradle wrapper --gradle-version 8.4 --distribution-type bin
# or download it from:
#   https://raw.githubusercontent.com/gradle/gradle/v8.4.0/gradle/wrapper/gradle-wrapper.jar

##############################################################################
# Attempt to resolve the location of this script
app_path=$0
while [ -h "$app_path" ] ; do
    ls=$( ls -ld "$app_path" )
    link=${ls#*' -> '}
    case $link in
      /*)   app_path=$link ;;
      *)    app_path=$( dirname "$app_path" )/"$link" ;;
    esac
done
APP_HOME=$( cd "$( dirname "$app_path" )" && pwd -P ) || exit

APP_NAME="Gradle"
APP_BASE_NAME=${0##*/}

DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'
MAX_FD=maximum

warn()  { echo "$*"; }
die()   { echo; echo "$*"; echo; exit 1; }

# OS detection
cygwin=false; msys=false; darwin=false; nonstop=false
case "$( uname )" in
  CYGWIN* )        cygwin=true  ;;
  Darwin* )        darwin=true  ;;
  MSYS* | MINGW* ) msys=true    ;;
  NONSTOP* )       nonstop=true ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Ensure gradle-wrapper.jar is present
if [ ! -f "$CLASSPATH" ]; then
    die "ERROR: gradle-wrapper.jar not found at $CLASSPATH.
Regenerate it with:
  gradle wrapper --gradle-version 8.4 --distribution-type bin
or download it from:
  https://raw.githubusercontent.com/gradle/gradle/v8.4.0/gradle/wrapper/gradle-wrapper.jar"
fi

# Determine java command
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME"
    fi
else
    JAVACMD=java
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and 'java' was not found in PATH."
fi

# Increase maximum file descriptors if possible
if ! "$cygwin" && ! "$darwin" && ! "$nonstop" ; then
    case $MAX_FD in
      max*) MAX_FD=$( ulimit -H -n ) || warn "Could not query max file descriptors" ;;
    esac
    case $MAX_FD in
      '' | soft) :;;
      *) ulimit -n "$MAX_FD" || warn "Could not set max file descriptors to $MAX_FD" ;;
    esac
fi

# Convert paths for Cygwin / MSYS
if "$cygwin" || "$msys" ; then
    APP_HOME=$( cygpath --path --mixed "$APP_HOME" )
    CLASSPATH=$( cygpath --path --mixed "$CLASSPATH" )
    JAVACMD=$( cygpath --unix "$JAVACMD" )
    for arg do
        case $arg in
          -*)   : ;;
          /?*)  t=${arg#/} t=/${t%%/*}
                [ -e "$t" ] && arg=$( cygpath --path --ignore --mixed "$arg" ) ;;
          *)    : ;;
        esac
        set -- "$arg" "$@"
        shift
    done
fi

# Build JVM opts from env vars
eval "set -- $(
    printf '%s\n' "$DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS" |
    xargs -n1 |
    sed 's~[^-[:alnum:]+,./:=@_]~\\&~g;' |
    tr '\n' ' '
)" '"$@"'

exec "$JAVACMD" "$@" \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
